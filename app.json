{
  "expo": {
    "name": "Will It Fit?",
    "slug": "willItFit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "willitfit",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Allow Will It Fit? to photograph your items.",
        "NSLocalNetworkUsageDescription": "Allows Will It Fit? to connect to the Metro bundler on your development machine.",
        "NSBonjourServices": ["_metro._tcp"]
      },
      "bundleIdentifier": "com.anonymous.willItFit"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Will It Fit? to photograph your items."
        }
      ]
    ]
  }
}
